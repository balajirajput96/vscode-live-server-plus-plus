# 🔐 Environment Configuration Template
# Copy this file to .env and configure your settings
# cp .env.template .env

# ==========================================
# 🚀 n8n Automation Platform Configuration
# ==========================================

# n8n Encryption Key (Required) - Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=

# Domain for your n8n instance (for production with HTTPS)
DOMAIN=

# Email for SSL certificates (required for HTTPS)
EMAIL=

# Webhook URL for external services to call your n8n workflows
# For local development: http://localhost:5678/webhook/
# For production: https://yourdomain.com/webhook/
WEBHOOK_URL=

# n8n Database Configuration
N8N_DB_TYPE=sqlite
N8N_DB_SQLITE_FILE=/data/database.sqlite

# Security Settings
N8N_SECURE_COOKIE=false
N8N_TRUST_PROXY=true

# ==========================================
# 🌐 Web Server Configuration
# ==========================================

# Port for career automation dashboard
WEB_SERVER_PORT=3000

# Port for n8n (default is 5678)
N8N_PORT=5678

# ==========================================
# 🔗 VPN Configuration (Optional)
# ==========================================

# Path to OpenVPN configuration file
VPN_CONFIG=

# VPN Username (if required)
VPN_USERNAME=

# VPN Password (if required)
VPN_PASSWORD=

# ==========================================
# 🤖 AI Service API Keys
# ==========================================

# OpenAI API Key for ChatGPT integration
OPENAI_API_KEY=

# Perplexity AI API Key
PERPLEXITY_API_KEY=

# Google AI/Gemini API Key
GOOGLE_AI_API_KEY=

# ==========================================
# 📱 Social Media Integration
# ==========================================

# LinkedIn API Credentials
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Facebook API Credentials
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=

# Twitter/X API Credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ==========================================
# 📧 Email Configuration
# ==========================================

# SMTP Settings for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ==========================================
# 💼 Job Search Integration
# ==========================================

# Indeed API Key
INDEED_API_KEY=

# LinkedIn Job Search API
LINKEDIN_JOB_API_KEY=

# Naukri.com API (if available)
NAUKRI_API_KEY=

# ==========================================
# 📊 Analytics and Monitoring
# ==========================================

# Google Analytics Tracking ID
GA_TRACKING_ID=

# Mixpanel Project Token
MIXPANEL_TOKEN=

# ==========================================
# 🏥 Health Check Configuration
# ==========================================

# Health check interval in minutes
HEALTH_CHECK_INTERVAL=30

# Notification webhook for health alerts
HEALTH_ALERT_WEBHOOK=

# ==========================================
# 🔄 Backup Configuration
# ==========================================

# Backup frequency (daily, weekly, monthly)
BACKUP_FREQUENCY=daily

# Backup storage location
BACKUP_LOCATION=./backups

# Cloud backup settings (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Google Drive backup (optional)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=

# ==========================================
# 🚨 Security Configuration
# ==========================================

# API Rate limiting
API_RATE_LIMIT=100

# Session timeout in minutes
SESSION_TIMEOUT=60

# Enable/disable debug logging
DEBUG_MODE=false

# ==========================================
# 📝 Custom Configuration
# ==========================================

# Your name for personalization
USER_NAME=

# Your profession/industry
USER_PROFESSION="Biotechnology Professional"

# Target companies (comma-separated)
TARGET_COMPANIES="Sun Pharma,Biocon,Dr. Reddy's,Cipla,Lupin"

# Preferred job locations
PREFERRED_LOCATIONS="Mumbai,Bangalore,Hyderabad,Pune"

# Experience level
EXPERIENCE_LEVEL="Entry Level"

# Skills (comma-separated)
SKILLS="Python,Data Analysis,Bioinformatics,Machine Learning,SQL"

# ==========================================
# 🔧 Advanced Settings (Optional)
# ==========================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Custom scripts directory
CUSTOM_SCRIPTS_DIR=./custom-scripts

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Maximum log file size in MB
MAX_LOG_SIZE=100

# Number of log files to keep
LOG_ROTATION=5N8N_ENCRYPTION_KEY=test_key_for_demo
