# Environment Variables for n8n Setup
# Copy this file to .env and modify the values

# Domain Configuration
DOMAIN=your-domain.com
EMAIL=your-email@domain.com
WEBHOOK_URL=https://your-domain.com/

# n8n Configuration
N8N_ENCRYPTION_KEY=your-32-char-encryption-key-here
N8N_USER=admin
N8N_PASSWORD=secure-password-here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SENDER=your-email@gmail.com

# Account Management
PRIMARY_EMAIL=balaji.web.design1@gmail.com
SECONDARY_EMAIL=22034563001@paruluniversity.ac.in

# Security
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true
PROTOCOL=https

# Database (optional - for production)
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=n8n
DB_USERNAME=n8n_user
DB_PASSWORD=n8n_password

# Redis (for queue mode - optional)
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=0