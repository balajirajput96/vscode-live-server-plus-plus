# ----- General -----
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# ----- Security / Privacy -----
# Generate a strong key: openssl rand -base64 48
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY
# If serving over HTTPS behind proxy, set true; for localhost HTTP, false.
N8N_SECURE_COOKIE=false
N8N_RUNNERS_ENABLED=true
# Opt-out of telemetry if you prefer
N8N_DIAGNOSTICS_ENABLED=false
# Enable Prometheus /metrics (optional)
N8N_METRICS=false

# Optional basic auth
# N8N_BASIC_AUTH_USERNAME=admin
# N8N_BASIC_AUTH_PASSWORD=very-strong-password

# ----- URL / Proxy -----
# Local (no proxy):
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_PROTOCOL=http
# WEBHOOK_URL=http://localhost:5678/
# N8N_TRUST_PROXY=false

# Domain + HTTPS via Caddy:
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_TRUST_PROXY=true

# ----- Database (Postgres) -----
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ----- Executions (Queue mode + pruning) -----
EXECUTIONS_MODE=queue
# How much data to store
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
# Pruning policy
EXECUTIONS_DATA_PRUNE=true
# Keep executions for 14 days (in hours)
EXECUTIONS_DATA_MAX_AGE=336
# Max count to prune per cycle
EXECUTIONS_DATA_PRUNE_MAX_COUNT=100
# Worker concurrency per container
WORKER_CONCURRENCY=5
# Optional payload limit (MB)
# N8N_PAYLOAD_SIZE_MAX=64

# ----- Caddy / TLS -----
ACME_EMAIL=you@example.com
DOMAIN=n8n.example.com