# -----------------------------------------------------------------------------
# n8n Basic Configuration
# -----------------------------------------------------------------------------
# The user for basic authentication.
N8N_BASIC_AUTH_USER=user

# The password for basic authentication.
# PLEASE CHANGE THIS!
N8N_BASIC_AUTH_PASSWORD=password

# The port n8n will run on.
N8N_PORT=5678

# The Docker image tag for n8n.
N8N_IMAGE_TAG=latest

# The address n8n will listen on.
N8N_LISTEN_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# n8n Production Configuration
# -----------------------------------------------------------------------------
# Your domain name for production deployment.
# Example: n8n.your-domain.com
DOMAIN=n8n.example.com

# Your email address for Let's Encrypt SSL certificate.
EMAIL=user@example.com

# Set to true when running on a custom domain with SSL.
N8N_SECURE_COOKIE=false

# The protocol to use (http or https).
N8N_PROTOCOL=http

# -----------------------------------------------------------------------------
# Webhook and API Configuration
# -----------------------------------------------------------------------------
# The full URL that webhooks will be sent to.
# For local deployment, this is typically http://localhost:5678.
# For production, this is https://your-domain.com.
WEBHOOK_URL=http://localhost:5678

# A strong, randomly generated key for encrypting credentials.
# You can generate one with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_STRONG_BASE64_KEY