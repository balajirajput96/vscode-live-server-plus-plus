# ----- General -----
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# ----- Security / Privacy -----
# Generate a strong key: openssl rand -base64 48
# IMPORTANT: Use a unique key for each installation to ensure data security
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY
# If serving over HTTPS behind proxy, set true; for localhost HTTP, false.
N8N_SECURE_COOKIE=false
N8N_RUNNERS_ENABLED=true
# Opt-out of telemetry if you prefer
N8N_DIAGNOSTICS_ENABLED=false
# Enable Prometheus /metrics (optional)
N8N_METRICS=false

# Optional basic auth for additional security layer
# Uncomment and set strong credentials if you want extra protection
# N8N_BASIC_AUTH_USERNAME=admin
# N8N_BASIC_AUTH_PASSWORD=very-strong-password

# ----- Email Configuration (for workflow notifications) -----
# Configure SMTP for sending emails from workflows
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.gmail.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=your-email@gmail.com
# N8N_SMTP_PASS=your-app-password
# N8N_SMTP_SENDER=your-email@gmail.com

# ----- URL / Proxy Configuration -----
# Choose ONE configuration below based on your setup:

# OPTION 1: Local development (no domain, HTTP only)
# Uncomment these lines for local development:
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_PROTOCOL=http
# WEBHOOK_URL=http://localhost:5678/
# N8N_TRUST_PROXY=false

# OPTION 2: Production with domain + HTTPS via Caddy
# Uncomment and modify these lines for production with your domain:
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_TRUST_PROXY=true

# OPTION 3: Custom port or different configuration
# Modify as needed for your specific setup

# ----- Database (Postgres) -----
POSTGRES_DB=n8n
POSTGRES_USER=n8n
# IMPORTANT: Change this to a strong, unique password
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ----- Workflow Data Backup & Migration -----
# These settings affect data retention and are important for backups
# Set to 'all' if you want to keep execution data for migration purposes
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true

# ----- Executions (Queue mode + pruning) -----
EXECUTIONS_MODE=queue
# Pruning policy - adjust based on your storage needs and backup requirements
EXECUTIONS_DATA_PRUNE=true
# Keep executions for 14 days (in hours) - increase if you need longer retention
EXECUTIONS_DATA_MAX_AGE=336
# Max count to prune per cycle - increase for larger installations
EXECUTIONS_DATA_PRUNE_MAX_COUNT=100
# Worker concurrency per container - adjust based on your server resources
WORKER_CONCURRENCY=5
# Optional payload limit (MB) - uncomment if you need to handle large payloads
# N8N_PAYLOAD_SIZE_MAX=64

# ----- Workflow Import/Export Settings -----
# Enable workflow sharing and import/export features
N8N_TEMPLATES_ENABLED=true
N8N_PERSONALIZATION_ENABLED=true

# ----- Caddy / TLS Configuration -----
# Required for HTTPS setup with automatic SSL certificates
# Replace with your actual email and domain
ACME_EMAIL=you@example.com
DOMAIN=n8n.example.com

# ----- User Account Configuration -----
# Default admin user settings (only used during initial setup)
# Change these to your preferred admin credentials
# N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_JWT_SECRET
# N8N_USER_MANAGEMENT_DISABLED=false