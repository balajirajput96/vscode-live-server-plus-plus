# Environment Configuration for n8n Workflow
# Copy this file to .env and update with your actual credentials

# =================================
# Basic Configuration
# =================================
DOMAIN=your-domain.com
EMAIL=balaji.web.design1@gmail.com
WEBHOOK_URL=https://your-domain.com/webhook/

# Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=your-32-character-encryption-key-here

# =================================
# n8n Configuration
# =================================
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST=0.0.0.0
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true
N8N_LOG_LEVEL=info

# =================================
# Gmail Configuration (Parul University)
# =================================
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_ACCESS_TOKEN=your-access-token
GMAIL_USER_EMAIL=balaji.web.design1@gmail.com

# =================================
# GitHub Integration
# =================================
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=balajirajput96
GITHUB_REPO_PREFIX=n8n-automation

# =================================
# Google Docs Integration
# =================================
GOOGLE_DOCS_API_KEY=your-google-docs-api-key
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# =================================
# VPN Configuration
# =================================
VPN_PROVIDER=nordvpn
VPN_API_KEY=your-vpn-provider-api-key
VPN_COUNTRIES=US,UK,IN,CA,AU,DE,JP
VPN_AUTO_SWITCH=true
VPN_ROTATION_INTERVAL=3600

# =================================
# Local AI Configuration
# =================================
LOCAL_AI_ENDPOINT=http://localhost:8080
LOCAL_AI_PORT=8080
GEMMA_MODEL_PATH=./models/gemma-3n
SHAKTI_MODEL_PATH=./models/shakti
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# =================================
# Database Configuration
# =================================
DB_TYPE=sqlite
DB_SQLITE_DATABASE=./n8n-database.sqlite
# For PostgreSQL:
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=postgres
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=n8n-password

# =================================
# Redis Configuration (for scaling)
# =================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
N8N_REDIS_HOST=redis
N8N_REDIS_PORT=6379
N8N_REDIS_PASSWORD=redis-password

# =================================
# Security Configuration
# =================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=balaji
N8N_BASIC_AUTH_PASSWORD=secure-password-here
N8N_JWT_AUTH_HEADER=authorization
N8N_JWT_AUTH_HEADER_VALUE_PREFIX=Bearer

# =================================
# Performance Configuration
# =================================
N8N_PAYLOAD_SIZE_MAX=16
N8N_EXECUTIONS_TIMEOUT=3600
N8N_EXECUTIONS_TIMEOUT_MAX=7200
N8N_EXECUTIONS_DATA_PRUNE=true
N8N_EXECUTIONS_DATA_MAX_AGE=336

# =================================
# Webhook Configuration
# =================================
N8N_WEBHOOK_URL=${WEBHOOK_URL}
N8N_WEBHOOK_TUNNEL_URL=${WEBHOOK_URL}
N8N_DEFAULT_LOCALE=hi

# =================================
# File Storage Configuration
# =================================
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_BINARY_DATA_TTL=24
N8N_BINARY_DATA_STORAGE_PATH=./binary-data

# =================================
# Monitoring & Logging
# =================================
N8N_METRICS=true
N8N_LOG_OUTPUT=console,file
N8N_LOG_FILE_COUNT_MAX=5
N8N_LOG_FILE_SIZE_MAX=16m

# =================================
# Development Configuration
# =================================
NODE_ENV=production
N8N_SKIP_WEBHOOK_DEREGISTRATION_SHUTDOWN=true

# =================================
# Custom Nodes Configuration
# =================================
N8N_CUSTOM_EXTENSIONS=./custom-nodes
N8N_EXTERNAL_MODULES=@n8n/nodes-langchain,n8n-nodes-puppeteer

# =================================
# Notification Configuration
# =================================
NOTIFICATION_EMAIL=balaji.web.design1@gmail.com
NOTIFICATION_WEBHOOK=${WEBHOOK_URL}/notifications
SLACK_WEBHOOK_URL=your-slack-webhook-url
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# =================================
# Backup Configuration
# =================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-s3-bucket
BACKUP_S3_REGION=us-west-2

# =================================
# API Rate Limiting
# =================================
API_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_SKIP_SUCCESSFUL=true

# =================================
# Queue Configuration
# =================================
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=redis-password
QUEUE_WORKER_TIMEOUT=30

# =================================
# Health Check Configuration
# =================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=5679
HEALTH_CHECK_PATH=/health

# =================================
# Timezone Configuration
# =================================
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# =================================
# Phone Optimization
# =================================
MOBILE_OPTIMIZED=true
OFFLINE_MODE_ENABLED=true
LOW_BANDWIDTH_MODE=true
CACHE_ENABLED=true
COMPRESSION_ENABLED=true