# Example Environment Configuration
# This is a sample .env file showing the structure
# Copy from .env.template and fill with your actual values

# Email Configuration  
GOOGLE_PRIMARY_EMAIL=john.doe@gmail.com
MS_PRIMARY_EMAIL=john.doe@outlook.com

# API Keys
TAILSCALE_AUTHKEY=tskey-auth-example123456789
OPENAI_API_KEY=sk-example123456789abcdef
YOUTUBE_API_KEY=AIzaSyExample123456789

# Database Configuration (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Server Configuration
SERVER_PORT=3000
NODE_ENV=production

# n8n Configuration
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=secure-password-123

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Monitoring Configuration
HEALTH_CHECK_INTERVAL=300
ALERT_EMAIL=alerts@yourdomain.com

# Security Configuration
JWT_SECRET=your-jwt-secret-key-here
ENCRYPTION_KEY=your-32-character-encryption-key