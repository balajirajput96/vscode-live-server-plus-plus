# Environment Configuration for Biotech Career Automation Agent

# Required Tokens and Credentials
# ================================

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_TARGET_NUMBER=91xxxxxxxxxx

# Google Services (Use service account JSON as base64 encoded string)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"..."}
GOOGLE_SHEETS_JOB_TRACKING_ID=your_job_tracking_sheet_id
GOOGLE_SHEETS_LEARNING_ID=your_learning_sheet_id
GOOGLE_SHEETS_KPI_ID=your_kpi_sheet_id
GOOGLE_CALENDAR_ID=primary

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your_github_username
GITHUB_REPOSITORY_OWNER=your_repo_owner
GITHUB_REPOSITORY_NAME=your_repo_name

# Azure ML
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_RESOURCE_GROUP=your_resource_group
AZURE_ML_WORKSPACE=your_ml_workspace_name

# Social Media APIs
BUFFER_ACCESS_TOKEN=your_buffer_token
META_ACCESS_TOKEN=your_meta_token
FACEBOOK_PAGE_ID=your_facebook_page_id
LINKEDIN_PROFILE_ID=your_linkedin_profile_id
TWITTER_PROFILE_ID=your_twitter_profile_id

# Learning Plan Configuration
LEARNING_PLAN_START_DATE=2024-01-01

# Logging Configuration
LOG_LEVEL=info

# Optional: Custom configurations
CI_NOTIFICATION_ENABLED=true
DAILY_AUTOMATION_ENABLED=true
WEEKLY_REPORTS_ENABLED=true