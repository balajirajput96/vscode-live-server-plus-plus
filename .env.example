# n8n Environment Configuration

# Basic Configuration
DOMAIN=n8n.yourdomain.com
EMAIL=admin@yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com/

# n8n Core Settings
N8N_ENCRYPTION_KEY=your-32-character-encryption-key-here
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=${WEBHOOK_URL}

# Security Settings
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true

# Database Configuration (for production)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your-secure-password

# Account Migration Settings
SOURCE_ACCOUNT=balaji.web.design1@gmail.com
TARGET_ACCOUNT=22034563001@paruluniversity.ac.in
MIGRATION_API_KEY=your-migration-api-key

# Performance & Offline Settings
N8N_CACHE_ENABLED=true
N8N_DISABLE_UI=false
N8N_LOG_LEVEL=info
N8N_METRICS=true
N8N_QUEUE_BULL_REDIS_HOST=redis
N8N_QUEUE_BULL_REDIS_PORT=6379

# High-Speed Configuration
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_BINARY_DATA_TTL=1440
N8N_EXECUTE_IN_PROCESS=true
N8N_SKIP_HEALTH_CHECK=false

# Pro Features Configuration
N8N_LICENSE_KEY=your-pro-license-key
N8N_USER_MANAGEMENT_JWT_SECRET=your-jwt-secret
N8N_ENCRYPTION_KEY=your-encryption-key

# Webhook Configuration
WEBHOOK_TUNNEL_URL=${WEBHOOK_URL}
N8N_PAYLOAD_SIZE_MAX=16

# Email Configuration (for notifications)
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=${TARGET_ACCOUNT}
N8N_SMTP_PASS=your-app-password
N8N_SMTP_SENDER=${TARGET_ACCOUNT}