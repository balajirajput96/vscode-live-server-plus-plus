# Image
N8N_IMAGE_TAG=1.82.1

# Timezone
TZ=Asia/Kolkata
GENERIC_TIMEZONE=Asia/Kolkata

# Local port (for docker-compose.basic.yml)
N8N_PORT=5678

# Domain + HTTPS (for reverse proxy setup) - Parul University Configuration
DOMAIN=n8n-balaji.paruluniversity.ac.in
EMAIL=balaji.web.design1@gmail.com
WEBHOOK_URL=https://n8n-balaji.paruluniversity.ac.in/

# n8n URL construction (keep these aligned with your deployment)
N8N_PROTOCOL=https
N8N_HOST=${DOMAIN}
N8N_TRUST_PROXY=true

# Security - Enhanced for Parul University Account
# Set to true for basic protection (recommended even behind proxy)
N8N_BASIC_AUTH=true
N8N_BASIC_AUTH_USERNAME=balaji
N8N_BASIC_AUTH_PASSWORD=ParulUniversity@2024!

# Cookies: true only when HTTPS; false for local HTTP
N8N_SECURE_COOKIE=true

# Encryption key for credentials (generate: `openssl rand -base64 32`)
N8N_ENCRYPTION_KEY=UGFydWxVbml2ZXJzaXR5QmFsYWppU2VjdXJlS2V5MjAyNA==

# Logging
N8N_LOG_LEVEL=info

# Enhanced payload limit for comprehensive automation
N8N_PAYLOAD_SIZE_MAX=64

# Parul University Specific Configuration
PARUL_UNIVERSITY_ACCOUNT=true
USER_EMAIL=balaji.web.design1@gmail.com
WORKFLOW_USER=balaji

# VPN Configuration
VPN_PROVIDER=expressvpn
VPN_COUNTRIES=US,UK,DE,JP,IN

# Local AI Configuration
LOCAL_AI_ENDPOINT=http://localhost:11434
GEMMA_MODEL=gemma:3b
SHAKTI_MODEL=shakti
OFFLINE_MODE=true

# GitHub Configuration
GITHUB_USERNAME=balajirajput96
GITHUB_REPO=vscode-live-server-plus-plus

# Google Services Configuration
GOOGLE_WORKSPACE_DOMAIN=paruluniversity.ac.in