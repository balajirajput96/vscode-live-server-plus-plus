# Image
N8N_IMAGE_TAG=1.82.1

# Timezone
TZ=Asia/Kolkata
GENERIC_TIMEZONE=Asia/Kolkata

# Local port (for docker-compose.basic.yml)
N8N_PORT=5678

# Domain + HTTPS (for reverse proxy setup)
DOMAIN=n8n.example.com
EMAIL=admin@example.com
WEBHOOK_URL=https://n8n.example.com/

# n8n URL construction (keep these aligned with your deployment)
N8N_PROTOCOL=https
N8N_HOST=${DOMAIN}
N8N_TRUST_PROXY=true

# Security
# Set to true for basic protection (recommended even behind proxy)
N8N_BASIC_AUTH=true
N8N_BASIC_AUTH_USERNAME=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong

# Cookies: true only when HTTPS; false for local HTTP
N8N_SECURE_COOKIE=true

# Encryption key for credentials (generate: `openssl rand -base64 32`)
N8N_ENCRYPTION_KEY=REPLACE_WITH_STRONG_BASE64_KEY

# Logging
N8N_LOG_LEVEL=info

# Optional: increase payload limit (MB) for large webhooks
# N8N_PAYLOAD_SIZE_MAX=32

# API Keys for automation workflows
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Production webhook URL for GitHub Actions and external integrations
N8N_WEBHOOK_URL=https://your-domain.com/webhook/balaji-automation

# Email configuration for notifications
FROM_EMAIL=your-email@domain.com
TO_EMAIL=2203456300001@paruluniversity.ac.in

# Google Drive configuration for file storage
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Azure deployment (if using Azure)
# AZURE_PUBLISH_PROFILE=your_azure_publish_profile_here
# AZURE_CREDENTIALS=your_azure_credentials_here

# Security settings
# Set to true to enable basic authentication even behind proxy
N8N_BASIC_AUTH_ENABLED=true

# University/Organization specific settings
UNIVERSITY_NAME=Parul University
UNIVERSITY_EMAIL_DOMAIN=paruluniversity.ac.in
UNIVERSITY_ADDRESS="P.O. Limda, Waghodia, Vadodara 391760"
UNIVERSITY_GST=24AADAP4952C2ZS

# Google Play Console settings (after D-U-N-S approval)
# DUNS_NUMBER=your_9_digit_duns_number
# PLAY_CONSOLE_ACCOUNT_EMAIL=your_developer_account_email