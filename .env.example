# n8n Environment Configuration
# Copy this to .env and fill in your values

# Domain and SSL
DOMAIN=n8n.paruluniversity.local
EMAIL=22034563001@paruluniversity.ac.in
WEBHOOK_URL=https://n8n.paruluniversity.local/

# n8n Configuration
N8N_ENCRYPTION_KEY=your_encryption_key_here
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# Database Configuration
DB_TYPE=postgres
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your_db_password_here

# Email Configuration (Gmail SMTP)
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=balaji.web.design1@gmail.com
N8N_SMTP_PASS=your_app_password_here
N8N_SMTP_SENDER=balaji.web.design1@gmail.com

# AI Integration
OPENAI_API_KEY=your_openai_key_here
GEMMA_MODEL_PATH=/models/gemma-3n
SHAKTI_MODEL_PATH=/models/shakti

# VPN Configuration
VPN_PROVIDERS=nordvpn,expressvpn,surfshark
VPN_COUNTRIES=US,UK,DE,IN,SG,JP,AU,CA

# Webhook URLs
GITHUB_WEBHOOK_URL=${WEBHOOK_URL}webhook/github
GMAIL_WEBHOOK_URL=${WEBHOOK_URL}webhook/gmail
VPN_WEBHOOK_URL=${WEBHOOK_URL}webhook/vpn

# API Keys and Credentials
GITHUB_TOKEN=your_github_token_here
GOOGLE_DOCS_CREDENTIALS=your_google_docs_credentials_here
VPN_API_KEY=your_vpn_api_key_here

# Performance Configuration
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console,file
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# Security
N8N_USER_MANAGEMENT_DISABLED=false
N8N_BASIC_AUTH_ACTIVE=false
N8N_JWT_AUTH_ACTIVE=true

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups/n8n