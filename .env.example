# n8n Environment Configuration Template
# Copy this file to .env and configure your settings

# Domain and SSL Configuration
DOMAIN=n8n.yourdomain.com
EMAIL=balaji.web.design1@gmail.com
WEBHOOK_URL=https://n8n.yourdomain.com/

# n8n Configuration
N8N_ENCRYPTION_KEY=your-encryption-key-here
N8N_SECURE_COOKIE=true
N8N_TRUST_PROXY=true
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# Database Configuration (PostgreSQL recommended for production)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your-secure-password

# Email Configuration for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=balaji.web.design1@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=balaji.web.design1@gmail.com

# University Email Configuration
UNIVERSITY_EMAIL=22034563001@paruluniversity.ac.in
UNIVERSITY_SMTP_HOST=smtp.gmail.com
UNIVERSITY_SMTP_PORT=587
UNIVERSITY_SMTP_USER=22034563001@paruluniversity.ac.in
UNIVERSITY_SMTP_PASS=your-university-app-password

# VPN Configuration
VPN_PROVIDER=expressvpn
VPN_USERNAME=your-vpn-username
VPN_PASSWORD=your-vpn-password

# Local AI Configuration
AI_MODEL_PATH=/app/models
GEMMA_MODEL_PATH=/app/models/gemma-3n
SHAKTI_MODEL_PATH=/app/models/shakti

# Security Settings
JWT_SECRET=your-jwt-secret-here
WEBHOOK_TUNNEL_URL=

# Timezone
TZ=Asia/Kolkata

# Development Settings (set to false for production)
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Performance Settings
N8N_EXECUTIONS_TIMEOUT=3600
N8N_EXECUTIONS_MAX_TIMEOUT=7200
N8N_EXECUTIONS_DATA_SAVE_ON_ERROR=all
N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=all