# n8n Automation Environment Configuration
# Copy this file to .env and configure your settings

# ===== VPN Configuration =====
VPN_SERVICE_PROVIDER=surfshark
SURFSHARK_USER=your_username
SURFSHARK_PASSWORD=your_password
SERVER_COUNTRIES=US,IN,DE,UK,JP

# ===== Database Configuration =====
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password

# ===== n8n Configuration =====
# CRITICAL: Generate a strong 32-character encryption key
# You can generate one using: openssl rand -base64 32
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_STRONG_32_CHAR_KEY

# Basic n8n settings
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_GENERIC_TIMEZONE=Asia/Kolkata

# Performance settings
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336

# ===== Network Configuration =====
HTTPPROXY_PORT=8888
N8N_PORT=5678
OLLAMA_PORT=11434

# ===== Worker Configuration =====
WORKER_CONCURRENCY=3
WORKER_REPLICAS=2

# ===== Optional: For production deployment =====
# DOMAIN=your-domain.com
# EMAIL=your-email@domain.com
# WEBHOOK_URL=https://your-domain.com/
# N8N_SECURE_COOKIE=true
# N8N_TRUST_PROXY=true