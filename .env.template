# GitHub Setup Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub - use GitHub Secrets instead

# Email Configuration
GOOGLE_PRIMARY_EMAIL=your.google.email@gmail.com
MS_PRIMARY_EMAIL=your.microsoft.email@outlook.com

# API Keys
TAILSCALE_AUTHKEY=tskey-your-tailscale-auth-key
OPENAI_API_KEY=sk-your-openai-api-key
YOUTUBE_API_KEY=your-youtube-api-key

# Database Configuration (if needed)
DATABASE_URL=your-database-connection-string

# Server Configuration
SERVER_PORT=3000
NODE_ENV=development

# n8n Configuration
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-secure-password

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Monitoring Configuration
HEALTH_CHECK_INTERVAL=300
ALERT_EMAIL=your.alerts@email.com

# Security Configuration
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key