# Copy this file to .env and fill in your values

# Domain Configuration (for HTTPS setup)
DOMAIN=your-domain.com
EMAIL=your-email@example.com

# Webhook URL (adjust based on your setup)
WEBHOOK_URL=https://your-domain.com/

# Database Configuration
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_strong_database_password

# n8n Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_strong_n8n_password

# Security
N8N_ENCRYPTION_KEY=your_encryption_key_here
# Generate with: openssl rand -base64 32

# Timezone
TIMEZONE=Asia/Kolkata

# VPN Configuration (optional)
EXPRESS_VPN_ACTIVATION_CODE=your_activation_code
NORD_VPN_USERNAME=your_username
NORD_VPN_PASSWORD=your_password

# GitHub Integration
GITHUB_TOKEN=your_github_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Monitoring
HEALTH_CHECK_INTERVAL=300  # 5 minutes
ALERT_EMAIL=admin@your-domain.com

# Node Environment
NODE_ENV=production