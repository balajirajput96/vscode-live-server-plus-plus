# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ========================================
# n8n Configuration
# ========================================

# Encryption key for n8n (generate with: openssl rand -base64 32)
N8N_ENCRYPTION_KEY=

# Public URL for webhooks (e.g., https://n8n.example.com/ or http://localhost:5678/)
WEBHOOK_URL=

# Set to true if using HTTPS, false for local development
N8N_SECURE_COOKIE=false

# Trust proxy headers (set to true when behind reverse proxy)
N8N_TRUST_PROXY=true

# ========================================
# Domain & Email Configuration
# ========================================

# Your domain name (for HTTPS setup with Caddy)
DOMAIN=localhost

# Email address for SSL certificate (Let's Encrypt)
EMAIL=your-email@example.com

# ========================================
# Database Configuration
# ========================================

# Database type (sqlite, mysql, postgres)
DB_TYPE=sqlite

# SQLite database file path (when using sqlite)
DB_SQLITE_DATABASE=n8n.sqlite

# MySQL/PostgreSQL configuration (when not using sqlite)
DB_MYSQL_HOST=
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=n8n
DB_MYSQL_USER=
DB_MYSQL_PASSWORD=

DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=

# ========================================
# n8n User & Permissions
# ========================================

# n8n user folder path
N8N_USER_FOLDER=/home/n8n/.n8n

# User management
N8N_USER_MANAGEMENT_DISABLED=false

# ========================================
# Security Settings
# ========================================

# JWT secret for session management
N8N_JWT_AUTH_HEADER=
N8N_JWT_AUTH_HEADER_VALUE=

# Basic auth (for simple protection)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ========================================
# GitHub Configuration
# ========================================

# GitHub personal access token (for GitHub Actions integration)
GITHUB_TOKEN=

# GitHub repository information
GITHUB_OWNER=
GITHUB_REPO=

# ========================================
# VPN Configuration
# ========================================

# Tailscale auth key (for VPN setup)
TAILSCALE_AUTH_KEY=

# VPN subnet configuration
VPN_SUBNET=100.64.0.0/10

# ========================================
# Backup Configuration
# ========================================

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup location
BACKUP_PATH=./backups

# Cloud backup configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=

# ========================================
# Monitoring & Alerting
# ========================================

# Health check interval (minutes)
HEALTH_CHECK_INTERVAL=30

# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=

# ========================================
# Application Settings
# ========================================

# Node environment
NODE_ENV=production

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Maximum payload size
N8N_PAYLOAD_SIZE_MAX=16

# Timezone
TZ=Asia/Kolkata

# ========================================
# Performance Settings
# ========================================

# Node.js memory limit
NODE_OPTIONS=--max-old-space-size=2048

# n8n process timeout
N8N_PROCESS_TIMEOUT=300

# Maximum executions
N8N_EXECUTIONS_SAVEALL=false
N8N_EXECUTIONS_DATA_MAX_AGE=168

# ========================================
# External Services
# ========================================

# API keys for external services
OPENAI_API_KEY=
GOOGLE_API_KEY=
SLACK_API_TOKEN=
TELEGRAM_BOT_TOKEN=

# ========================================
# Custom Settings
# ========================================

# Custom environment variables
CUSTOM_VAR_1=
CUSTOM_VAR_2=

# Feature flags
ENABLE_FEATURE_X=false
ENABLE_FEATURE_Y=true

# ========================================
# Development Settings (for local setup)
# ========================================

# Development mode
DEV_MODE=false

# Debug settings
DEBUG=false
DEBUG_PORT=9229

# Hot reload
ENABLE_HOT_RELOAD=false