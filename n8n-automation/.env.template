# n8n Automation Environment Configuration
# Copy this file to .env and update with your values

# Basic n8n Configuration
N8N_HOST=localhost
N8N_PROTOCOL=http
TIMEZONE=Asia/Kolkata

# Webhook Configuration
# For local development, use localhost
# For production, use your domain
WEBHOOK_URL=http://localhost:5678/

# Tunnel Configuration (optional)
# Get your auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Email Configuration (optional)
EMAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# API Keys for Automation (add as needed)
OPENAI_API_KEY=your_openai_api_key
LINKEDIN_API_KEY=your_linkedin_api_key
GITHUB_TOKEN=your_github_token

# Career Automation Specific
TARGET_COMPANIES=Sun Pharma,Zydus Cadila,Dr. Reddy's,Lupin,Cipla,Biocon
JOB_SEARCH_KEYWORDS=bioinformatics,data analysis,biotechnology,python,sql

# Notification Settings
SLACK_WEBHOOK_URL=your_slack_webhook_url
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Database Configuration (for advanced setups)
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=your_db_password