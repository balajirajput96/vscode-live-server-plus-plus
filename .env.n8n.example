# n8n Environment Configuration
# Copy this file to .env and update with your values

# VPN Configuration
VPN_SERVICE_PROVIDER=surfshark
SURFSHARK_USER=your_username
SURFSHARK_PASSWORD=your_password
SERVER_COUNTRIES=US,IN,DE,UK,JP

# Database Configuration
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password

# n8n Configuration
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_STRONG_32_CHAR_KEY
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_GENERIC_TIMEZONE=Asia/Kolkata

# Performance Settings
N8N_EXECUTIONS_DATA_MAX_AGE=336
N8N_LOG_LEVEL=warn
N8N_METRICS=true
N8N_QUEUE_BULL_REDIS_DB=0
N8N_QUEUE_HEALTH_CHECK_ACTIVE=true
WORKER_CONCURRENCY=3

# Google OAuth (Optional - configure in n8n UI)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# Email Configuration
NOTIFICATION_EMAIL=balaji.web.design1@gmail.com

# Ollama AI Models
DEFAULT_AI_MODEL=gemma2:2b-instruct-q4_K_M
BACKUP_AI_MODEL=phi3:3.8b-mini-instruct-4k-fp16