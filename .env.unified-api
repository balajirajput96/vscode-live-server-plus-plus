# Unified API Configuration Template
# Copy this to .env and fill in your actual values

# ===========================================
# n8n Configuration
# ===========================================

# n8n Base Settings (use existing .env.example)
N8N_IMAGE_TAG=1.82.1
TZ=Asia/Kolkata
GENERIC_TIMEZONE=Asia/Kolkata

# Local Development
N8N_PORT=5678
N8N_SECURE_COOKIE=false

# Production Domain (for HTTPS)
DOMAIN=your-domain.com
EMAIL=your-email@example.com
WEBHOOK_URL=https://your-domain.com/
N8N_PROTOCOL=https
N8N_HOST=${DOMAIN}
N8N_TRUST_PROXY=true

# Authentication
N8N_BASIC_AUTH=true
N8N_BASIC_AUTH_USERNAME=admin
N8N_BASIC_AUTH_PASSWORD=your-strong-password

# Security Key (generate with: openssl rand -base64 32)
N8N_ENCRYPTION_KEY=your-generated-encryption-key

# ===========================================
# Unified API Configuration
# ===========================================

# Main API Endpoint (set this in GitHub Secrets)
N8N_UNIFIED_API_URL=https://your-n8n-instance.com/webhook/unified-api

# ===========================================
# Service Integrations - Replace These Values
# ===========================================

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# GitHub Integration
GITHUB_OWNER=balajirajput96
GITHUB_REPO=vscode-live-server-plus-plus
GITHUB_TOKEN=your-github-personal-access-token

# Google Services
GOOGLE_DRIVE_FILE_ID=your-google-drive-file-id
GOOGLE_SHEETS_ID=your-google-sheets-document-id

# Email Configuration (default recipient)
DEFAULT_EMAIL=2203456300001@paruluniversity.ac.in

# ===========================================
# API Request Types
# ===========================================

# Supported request types for the unified API:
# - ai: OpenAI chat completion with notifications
# - github: Create GitHub issues
# - docs: Retrieve Google Drive documents
# - log: Log data to Google Sheets

# ===========================================
# Setup Instructions
# ===========================================

# 1. Copy this file to .env
# 2. Replace all REPLACE_* values with your actual credentials
# 3. Set up n8n using docker-compose:
#    docker compose --env-file .env -f docker-compose.basic.yml up -d
# 4. Import the workflow from n8n-workflows/unified-api-router.json
# 5. Configure credentials in n8n:
#    - OpenAI API key
#    - Gmail OAuth
#    - Google Drive/Sheets OAuth or Service Account
#    - Telegram Bot Token
#    - GitHub Personal Access Token
# 6. Add N8N_UNIFIED_API_URL to GitHub repository secrets
# 7. Test the API using the provided examples

# ===========================================
# Example API Requests
# ===========================================

# AI Request:
# curl -X POST "$N8N_UNIFIED_API_URL" \
#   -H "Content-Type: application/json" \
#   -d '{"type":"ai","query":"What are latest biotech trends?","email":"user@example.com"}'

# GitHub Request:
# curl -X POST "$N8N_UNIFIED_API_URL" \
#   -H "Content-Type: application/json" \
#   -d '{"type":"github","title":"New Feature Request","description":"Add new functionality"}'

# Docs Request:
# curl -X POST "$N8N_UNIFIED_API_URL" \
#   -H "Content-Type: application/json" \
#   -d '{"type":"docs","file_id":"your-drive-file-id"}'

# Log Request:
# curl -X POST "$N8N_UNIFIED_API_URL" \
#   -H "Content-Type: application/json" \
#   -d '{"type":"log","message":"Test log entry","email":"user@example.com"}'