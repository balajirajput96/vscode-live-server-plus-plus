{
  "name": "Unified_API_Router_v1",
  "nodes": [
    {
      "parameters": {
        "path": "unified-api",
        "responseMode": "onReceived",
        "httpMethod": "POST"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "id": "webhook-node"
    },
    {
      "parameters": {
        "options": {},
        "functionCode": "// Route requests based on type parameter\nconst requestType = (items[0].json.type || '').toLowerCase();\nconst data = items[0].json;\n\n// Log the incoming request\nconsole.log('Unified API Request:', { type: requestType, data });\n\n// Add routing metadata\nreturn [{ \n  ...data,\n  routeType: requestType,\n  timestamp: new Date().toISOString(),\n  requestId: Math.random().toString(36).substr(2, 9)\n}];"
      },
      "name": "Request Router",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [440, 300],
      "id": "router-node"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "ai-condition",
              "leftValue": "={{ $json.routeType }}",
              "rightValue": "ai",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "name": "Route to AI",
