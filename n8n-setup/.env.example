# Environment Configuration for n8n Automation System
# Copy this file to .env and update with your actual credentials

# ==============================================
# BASIC n8n CONFIGURATION
# ==============================================

# Your Parul University Gmail Account
N8N_EMAIL=22034563001@paruluniversity.ac.in
N8N_USER=balaji_admin
N8N_PASSWORD=change_me_secure_password

# Your Personal Gmail for Notifications  
NOTIFICATION_EMAIL=balaji.web.design1@gmail.com

# ==============================================
# DOMAIN & WEBHOOK SETTINGS
# ==============================================

# Local development
DOMAIN=localhost
WEBHOOK_URL=http://localhost:5678

# Production (uncomment for production use)
# DOMAIN=your-domain.com
# WEBHOOK_URL=https://your-domain.com

# ==============================================
# SECURITY SETTINGS
# ==============================================

# Generate secure key: openssl rand -base64 32
N8N_ENCRYPTION_KEY=your_32_character_encryption_key_here

# SSL Settings (set to true for production)
N8N_SECURE_COOKIE=false
N8N_TRUST_PROXY=false

# Basic Auth (recommended for security)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=${N8N_USER}
N8N_BASIC_AUTH_PASSWORD=${N8N_PASSWORD}

# ==============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==============================================

# Gmail SMTP Settings for Parul University Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=22034563001@paruluniversity.ac.in
SMTP_PASS=your_gmail_app_password

# Personal Gmail for Notifications
NOTIFICATION_SMTP_USER=balaji.web.design1@gmail.com
NOTIFICATION_SMTP_PASS=your_personal_gmail_app_password

# ==============================================
# API KEYS & INTEGRATIONS
# ==============================================

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=balajirajput96

# Google APIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# OpenAI (for AI features)
OPENAI_API_KEY=your_openai_api_key

# ==============================================
# VPN CONFIGURATION
# ==============================================

# VPN Service API Keys (examples)
NORDVPN_USERNAME=your_nordvpn_username
NORDVPN_PASSWORD=your_nordvpn_password

# ExpressVPN
EXPRESSVPN_API_KEY=your_expressvpn_api_key

# ProtonVPN
PROTONVPN_USERNAME=your_protonvpn_username
PROTONVPN_PASSWORD=your_protonvpn_password

# ==============================================
# LOCAL AI CONFIGURATION
# ==============================================

# Ollama Server (for local AI models)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_GEMMA=gemma:3b
OLLAMA_MODEL_SHAKTI=shakti:latest

# Local Model Paths
AI_MODELS_PATH=/home/node/.n8n/ai-models
GEMMA_MODEL_PATH=${AI_MODELS_PATH}/gemma-3b
SHAKTI_MODEL_PATH=${AI_MODELS_PATH}/shakti

# ==============================================
# PERFORMANCE SETTINGS
# ==============================================

# High Performance Mode
N8N_HIGH_PERFORMANCE=true
N8N_CACHE_ENABLED=true
N8N_PARALLEL_EXECUTION=true

# Memory & CPU Limits
N8N_MEMORY_LIMIT=4096
N8N_CPU_LIMIT=2

# Execution Settings
N8N_EXECUTION_TIMEOUT=300
N8N_MAX_EXECUTION_TIMEOUT=3600

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# SQLite (default for development)
DB_TYPE=sqlite
DB_SQLITE_DATABASE=database.sqlite

# PostgreSQL (recommended for production)
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n_user
# DB_POSTGRESDB_PASSWORD=secure_db_password

# ==============================================
# MONITORING & LOGGING
# ==============================================

# Log Level (debug, info, warn, error)
N8N_LOG_LEVEL=info

# File Logging
N8N_LOG_FILE_ENABLED=true
N8N_LOG_FILE_LOCATION=/home/node/.n8n/logs/

# Metrics
N8N_METRICS=true
N8N_METRICS_PREFIX=n8n_

# ==============================================
# BACKUP & RECOVERY
# ==============================================

# Backup Settings
BACKUP_ENABLED=true
BACKUP_LOCATION=/home/node/.n8n/backups/
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# ==============================================
# NOTIFICATIONS
# ==============================================

# Slack (optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Discord (optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ==============================================
# CUSTOM SETTINGS
# ==============================================

# Timezone
TZ=Asia/Kolkata

# Language
N8N_DEFAULT_LOCALE=en

# User Management
N8N_USER_MANAGEMENT_DISABLED=false

# Public API
N8N_PUBLIC_API_DISABLED=false

# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================

# Development Mode
NODE_ENV=production

# Debug Mode (set to true for debugging)
DEBUG=false

# Skip User Management Setup
N8N_SKIP_WEBHOOK_DEREGISTRATION_SHUTDOWN=true

# ==============================================
# NETWORK SETTINGS
# ==============================================

# Port Configuration
N8N_PORT=5678
N8N_PROTOCOL=http

# Proxy Settings (if behind reverse proxy)
# N8N_PROXY_HOPS=1

# ==============================================
# FEATURE FLAGS
# ==============================================

# Enable/Disable Features
N8N_TEMPLATES_ENABLED=true
N8N_ONBOARDING_FLOW_DISABLED=false
N8N_PERSONALIZATION_ENABLED=true

# ==============================================
# SECURITY HEADERS
# ==============================================

# CORS Settings
N8N_CORS_ORIGIN=*

# Additional Security
N8N_SECURE_COOKIE=${N8N_SECURE_COOKIE}
N8N_COOKIE_SAME_SITE=lax

# ==============================================
# END OF CONFIGURATION
# ==============================================