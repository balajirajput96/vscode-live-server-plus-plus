        "html": "<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background: linear-gradient(135deg, #16a085 0%, #f39c12 100%); color: white;\">\n  <h1 style=\"text-align: center; margin-bottom: 30px;\">🌍 VPN Successfully Connected!</h1>\n  \n  <div style=\"background: rgba(255,255,255,0.1); padding: 20px; border-radius: 10px; margin: 20px 0;\">\n    <h2>🔗 Connection Details</h2>\n    <p><strong>Country:</strong> {{$node[\"Select VPN Server\"].json[\"country\"]}} {{$node[\"Select VPN Server\"].json[\"flag\"]}}</p>\n    <p><strong>Server:</strong> {{$node[\"Select VPN Server\"].json[\"server\"]}}</p>\n    <p><strong>New IP:</strong> {{$json[\"ip\"]}}</p>\n    <p><strong>Location:</strong> {{$json[\"city\"]}}, {{$json[\"country_name\"]}}</p>\n    <p><strong>ISP:</strong> {{$json[\"org\"]}}</p>\n  </div>\n  \n  <div style=\"background: rgba(255,255,255,0.1); padding: 20px; border-radius: 10px; margin: 20px 0;\">\n    <h3>🎯 Available Benefits</h3>\n    <ul>\n      {{#each $node[\"Select VPN Server\"].json[\"benefits\"]}}\n      <li>✅ {{this}}</li>\n      {{/each}}\n    </ul>\n  </div>\n  \n  <div style=\"background: rgba(255,255,255,0.1); padding: 20px; border-radius: 10px; margin: 20px 0;\">\n    {{JSON.parse($node[\"AI Regional Benefits\"].json[\"response\"]).response}}\n  </div>\n  \n  <div style=\"background: rgba(255,255,255,0.1); padding: 20px; border-radius: 10px; margin: 20px 0;\">\n    <h3>🔧 VPN Controls</h3>\n    <p>To disconnect: <code>nordvpn disconnect</code></p>\n    <p>To switch countries, send a POST request to the VPN webhook with different country.</p>\n  </div>\n  \n  <p style=\"text-align: center; margin-top: 30px; font-style: italic;\">Enjoy secure browsing! 🔒</p>\n</div>",
        "options": {}
