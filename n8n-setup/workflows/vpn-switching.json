    {
      "parameters": {
        "jsCode": "// Available VPN countries with their benefits\nconst vpnCountries = {\n  'USA': {\n    benefits: ['Netflix US', 'Amazon Prime US', 'Hulu', 'Tech deals', 'Academic resources'],\n    server: 'us-east-1.nordvpn.com',\n    flag: '🇺🇸'\n  },\n  'UK': {\n    benefits: ['BBC iPlayer', 'UK Netflix', 'BritBox', 'UK deals', 'British journals'],\n    server: 'uk-london.nordvpn.com',\n    flag: '🇬🇧'\n  },\n  'Canada': {\n    benefits: ['Canadian Netflix', 'CBC', 'Government resources', 'Educational content'],\n    server: 'ca-toronto.nordvpn.com',\n    flag: '🇨🇦'\n  },\n  'Germany': {\n    benefits: ['German Netflix', 'EU content', 'Research papers', 'Tech resources'],\n    server: 'de-berlin.nordvpn.com',\n    flag: '🇩🇪'\n  },\n  'Japan': {\n    benefits: ['Japanese content', 'Anime platforms', 'Tech innovations', 'Cultural resources'],\n    server: 'jp-tokyo.nordvpn.com',\n    flag: '🇯🇵'\n  },\n  'Singapore': {\n    benefits: ['Asian content', 'Banking', 'Regional offers', 'Business resources'],\n    server: 'sg-singapore.nordvpn.com',\n    flag: '🇸🇬'\n  },\n  'Australia': {\n    benefits: ['Australian Netflix', 'Educational resources', 'Government services'],\n    server: 'au-sydney.nordvpn.com',\n    flag: '🇦🇺'\n  },\n  'India': {\n    benefits: ['Indian content', 'Local offers', 'Educational platforms', 'Government services'],\n    server: 'in-mumbai.nordvpn.com',\n    flag: '🇮🇳'\n  }\n};\n\nconst requestedCountry = $input.first().json.country.toUpperCase();\nconst targetCountry = vpnCountries[requestedCountry];\n\nif (!targetCountry) {\n  return [{\n    json: {\n      error: `Country ${requestedCountry} not supported`,\n      availableCountries: Object.keys(vpnCountries),\n      success: false\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    country: requestedCountry,\n    server: targetCountry.server,\n    benefits: targetCountry.benefits,\n    flag: targetCountry.flag,\n    success: true\n  }\n}];"
      },
      "id": "select-vpn-server",
      "name": "Select VPN Server",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "command": "nordvpn connect {{$json[\"server\"]}}",
